    },
    {
      "source": "/projects/vsi.html",
      "destination": "/pixerli.framer.website/projects/vsi.html"
    },
    {
      "source": "/projects/vednix",
      "destination": "/pixerli.framer.website/projects/vednix.html"
    },
    {
      "source": "/projects/vednix.html",
      "destination": "/pixerli.framer.website/projects/vednix.html"
    },
    {
      "source": "/projects/oliveclear",
      "destination": "/pixerli.framer.website/projects/oliveclear.html"
    },
    {
      "source": "/projects/oliveclear.html",
      "destination": "/pixerli.framer.website/projects/oliveclear.html"
    }
  ]
}
