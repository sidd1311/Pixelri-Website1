{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/pixerli.framer.website/index.html"
    },

    {
      "source": "/contact",
      "destination": "/pixerli.framer.website/contact.html"
    },
    {
      "source": "/contact.html",
      "destination": "/pixerli.framer.website/contact.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/pixerli.framer.website/privacy-policy.html"
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/pixerli.framer.website/privacy-policy.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/pixerli.framer.website/terms-of-service.html"
    },
    {
      "source": "/terms-of-service.html",
      "destination": "/pixerli.framer.website/terms-of-service.html"
    },
    {
      "source": "/projects",
      "destination": "/pixerli.framer.website/projects.html"
    },
    {
      "source": "/projects.html",
      "destination": "/pixerli.framer.website/projects.html"
    },
    {
